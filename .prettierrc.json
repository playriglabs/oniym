{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "tabWidth": 4,
  "printWidth": 100,
  "arrowParens": "always",
  "plugins": ["prettier-plugin-solidity"],
  "overrides": [
    {
      "files": "*.sol",
      "options": {
        "tabWidth": 4,
        "printWidth": 100,
        "singleQuote": false,
        "bracketSpacing": true
      }
    },
    {
      "files": ["*.md", "*.json"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
