# ── Deployer ──────────────────────────────────────────────────────────────────                                                                          
# Address corresponding to PRIVATE_KEY                                                                                                                    
DEPLOYER_ADDRESS=0xYourDeployerAddress 
                                                                                                                                                            
# Private key (no 0x prefix needed by forge, but include it — both work)
PRIVATE_KEY=0xYourPrivateKey           
                                                                                                                                                            
# ── Network ───────────────────────────────────────────────────────────────────
# Base Sepolia RPC — matches foundry.toml [rpc_endpoints] base_sepolia                                                                                    
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
                                                                                                                                                            
# ── Verification ──────────────────────────────────────────────────────────────
# Basescan API key (https://basescan.org/myapikey)                                                                                                        
BASESCAN_API_KEY=YourBasescanApiKey
                                                                                                                                                            
# ── Oracle (optional override) ────────────────────────────────────────────────
# Defaults to Base Sepolia if omitted. Override for mainnet:                                                                                              
# Base Sepolia: 0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb1                                                                                                
# Base Mainnet: 0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70                                                                                                
# CHAINLINK_ETH_USD_FEED=0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb1                                                                                       
                                                                                                                                                            
# ── USDC (optional override) ──────────────────────────────────────────────────                                                                          
# Defaults to Base Sepolia if omitted. Override for mainnet:                                                                                              
# Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e                                                                                                
# Base Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913                                                                                                
# USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e                                                                                                 
                                                                                                                                                            
# ── Register.s.sol (optional) ─────────────────────────────────────────────────                                                                          
# REGISTER_LABEL=myname                
# REGISTER_DURATION=2592000        # seconds (default: 30 days = 2592000)                                                                                 
# REGISTER_OWNER=0x...             # default: DEPLOYER_ADDRESS                                                                                            
# PAYMENT_TOKEN=0x036CbD53842c5426634e7929541eC2318f3dCF7e   # omit = ETH, USDC addr = USDC