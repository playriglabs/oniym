# ── Deployer ──────────────────────────────────────────────────────────────────
# Address corresponding to PRIVATE_KEY
DEPLOYER_ADDRESS=0xYourDeployerAddress

# Private key (no 0x prefix needed by forge, but include it — both work)
PRIVATE_KEY=0xYourPrivateKey

# ── Network ───────────────────────────────────────────────────────────────────
# Base Sepolia RPC — matches foundry.toml [rpc_endpoints] base_sepolia
# (get a free key at https://www.alchemy.com or https://infura.io)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Verification ──────────────────────────────────────────────────────────────
# Basescan API key (https://basescan.org/myapikey)
ETHERSCAN_API_KEY=YourBasescanApiKey

# ── Oracle (optional override) ────────────────────────────────────────────────
# Defaults to Base Sepolia Chainlink ETH/USD feed if omitted
# CHAINLINK_ETH_USD_FEED=0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb1
