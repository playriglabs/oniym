{
  "name": "@oniym/react",
  "version": "0.0.1",
  "description": "React hooks for Oniym — multichain naming service",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@oniym/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "viem": ">=2.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "viem": "^2.21.0"
  },
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/playriglabs/oniym.git",
    "directory": "react"
  },
  "homepage": "https://oniym.xyz",
  "author": "Playriglabs <hello@playriglabs.fun> (https://playriglabs.fun)",
  "license": "MIT",
  "keywords": ["oniym", "naming", "web3", "react", "hooks", "ens", "multichain"]
}
