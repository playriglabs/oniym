{
  "name": "oniym",
  "version": "0.0.1",
  "private": true,
  "description": "One name, all chains. Multichain-native naming service.",
  "author": "Playriglabs <hello@playriglabs.fun> (https://playriglabs.fun)",
  "license": "MIT",
  "homepage": "https://oniym.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/playriglabs/oniym.git"
  },
  "workspaces": [
    "indexer",
    "sdk",
    "web",
    "examples/*"
  ],
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vv",
    "contracts:coverage": "cd contracts && forge coverage",
    "contracts:slither": "cd contracts && slither .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,sol}\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-solidity": "^1.4.1",
    "typescript": "^5.7.2"
  }
}
