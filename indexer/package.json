{
  "name": "@oniym/indexer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation ponder dev --schema public",
    "start": "NODE_OPTIONS=--no-deprecation ponder start --schema public",
    "codegen": "ponder codegen",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "worker:dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "0.39.3",
    "hono": "^4.7.0",
    "ioredis": "^5.6.0",
    "ponder": "^0.9.0",
    "viem": "^2.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.101.0"
  }
}
